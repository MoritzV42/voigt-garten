---
import Sidebar from '../components/layout/Sidebar';
import BottomNav from '../components/layout/BottomNav';
import MobileHeader from '../components/layout/MobileHeader';
import AppOverlays from '../components/AppOverlays';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Refugium Etzdorf – Naturgarten mit Übernachtungsmöglichkeit in Sachsen. 5.300m² Südhang, Solar-Autarkie, eigener Brunnen. Betrieben von Refugium Naturgärten." } = Astro.props;
const canonicalUrl = `https://garten.infinityspace42.de${Astro.url.pathname}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${title} | Refugium Etzdorf`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Pannellum 360° Panorama Viewer -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.css" />
    <script src="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.js" is:inline></script>
    <title>{title} | Refugium Etzdorf</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": "Refugium Etzdorf",
      "description": "Naturgarten mit Übernachtungsmöglichkeit in Etzdorf im Rosental, Sachsen. 5.300m² Südhang mit Solar-Autarkie. Ein Standort von Refugium Naturgärten.",
      "url": "https://garten.infinityspace42.de",
      "telephone": "+4901652593763",
      "email": "garten@infinityspace42.de",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Etzdorf im Rosental",
        "addressRegion": "Sachsen",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.15,
        "longitude": 12.45
      },
      "priceRange": "30€ - 60€ pro Nacht",
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "Solarstrom", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Eigener Brunnen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Gartenhaus", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Wintergarten", "value": true}
      ]
    })} />
  </head>
  <body class="min-h-screen bg-garden-50 font-sans text-gray-800">
    <div class="min-h-screen">
      <!-- Desktop Sidebar -->
      <Sidebar client:load />

      <!-- Mobile Header -->
      <MobileHeader client:load />

      <!-- Main Content -->
      <main class="lg:pl-[264px]">
        <div class="py-0 pb-24 lg:pb-8">
          <slot />
        </div>

        <!-- Footer -->
        <footer class="border-t border-garden-200 bg-garden-50">
          <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-sm text-gray-500">
              <a href="/impressum" class="hover:text-garden-700 transition">Impressum</a>
              <span class="text-gray-300">·</span>
              <a href="/datenschutz" class="hover:text-garden-700 transition">Datenschutz</a>
              <span class="text-gray-300">·</span>
              <a href="/agb" class="hover:text-garden-700 transition">AGB</a>
              <span class="text-gray-300">·</span>
              <a href="/hausordnung" class="hover:text-garden-700 transition">Hausordnung</a>
            </div>
            <div class="mt-3 text-center text-xs text-gray-400">
              &copy; {new Date().getFullYear()} Refugium Naturgärten &middot;
              <a href="mailto:garten@infinityspace42.de" class="hover:text-garden-600 transition">
                garten@infinityspace42.de
              </a>
              <span class="mx-1.5">·</span>
              <a href="/admin" class="hover:text-garden-600 transition">Admin</a>
            </div>
          </div>
        </footer>
      </main>

      <!-- Mobile Bottom Nav -->
      <BottomNav client:load />

      <!-- Tutorial Overlays & AI Assistant -->
      <AppOverlays client:load />
    </div>

    <script>
      // Mailto links open in new tab on desktop
      if (window.matchMedia('(hover: hover)').matches) {
        document.querySelectorAll('a[href^="mailto:"]').forEach(link => {
          link.setAttribute('target', '_blank');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
