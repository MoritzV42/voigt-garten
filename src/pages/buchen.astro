---
import Layout from '../layouts/Layout.astro';
import BookingCalendar from '../components/BookingCalendar';
import BookingForm from '../components/BookingForm';

// PLACEHOLDER: Preise konfigurieren
const pricing = {
  perNight: 45, // Euro pro Nacht - PLACEHOLDER: Anpassen!
  weeklyDiscount: 15, // % Rabatt bei Wochenbuchung
  familyDiscount: 50, // % mit REFUGIUM-FAMILY Code
};
---

<Layout title="Buchen" description="Buche deinen Aufenthalt im Refugium Heideland – ein Standort von Refugium Naturgärten.">
  <!-- Header -->
  <section class="bg-gradient-to-b from-garden-100 to-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-garden-900 mb-4">
        Jetzt Buchen
      </h1>
      <p class="text-xl text-garden-700 max-w-2xl mx-auto">
        Wähle deinen Wunschzeitraum und erlebe Urlaub im Grünen.
      </p>
    </div>
  </section>

  <!-- Pricing Info -->
  <section class="py-8 bg-white border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div class="bg-garden-50 rounded-lg p-6">
          <div class="text-3xl font-bold text-garden-700">{pricing.perNight}€</div>
          <div class="text-gray-600">pro Nacht</div>
        </div>
        <div class="bg-garden-50 rounded-lg p-6">
          <div class="text-3xl font-bold text-garden-700">-{pricing.weeklyDiscount}%</div>
          <div class="text-gray-600">bei 7+ Nächten</div>
        </div>
        <div class="bg-amber-50 rounded-lg p-6 border-2 border-amber-200">
          <div class="text-3xl font-bold text-amber-700">-{pricing.familyDiscount}%</div>
          <div class="text-amber-800 font-medium">Familien-Rabatt</div>
          <div class="text-xs text-amber-600 mt-1">Code: REFUGIUM-FAMILY</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hanglage-Hinweis -->
  <section class="py-6 bg-garden-50 border-y border-garden-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start gap-3">
        <span class="text-2xl">🌄</span>
        <div>
          <h3 class="font-semibold text-garden-900 mb-1">Gut zu wissen</h3>
          <p class="text-sm text-garden-900 leading-relaxed">
            Das Refugium liegt an einem freundlichen Südhang (~10–15°) – familientauglich,
            auch mit kleinen Kindern (Aufsicht wie in jedem Garten). Festes Schuhwerk
            empfohlen. Dafür: absolute Ruhe, Weinberg und ein großes Panorama.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Calendar -->
        <div class="bg-white rounded-xl shadow-lg p-6">
          <h2 class="font-display text-2xl font-bold text-garden-900 mb-6">
            Verfügbarkeit
          </h2>
          <BookingCalendar client:load />
          <div class="mt-4 flex gap-4 text-sm">
            <div class="flex items-center gap-2">
              <div class="w-4 h-4 bg-green-200 rounded"></div>
              <span>Verfügbar</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-4 h-4 bg-red-200 rounded"></div>
              <span>Belegt</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-4 h-4 bg-blue-200 rounded"></div>
              <span>Ausgewählt</span>
            </div>
          </div>
        </div>

        <!-- Booking Form -->
        <div class="bg-white rounded-xl shadow-lg p-6" data-tutorial="booking-form">
          <h2 class="font-display text-2xl font-bold text-garden-900 mb-6">
            Buchung
          </h2>
          <BookingForm client:load pricing={pricing} />
        </div>
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center text-garden-900 mb-8">
        Gut zu wissen
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-garden-50 rounded-lg p-6">
          <h3 class="font-semibold text-garden-800 mb-2">🕐 Check-in / Check-out</h3>
          <p class="text-gray-600">
            Check-in ab 15:00 Uhr<br />
            Check-out bis 11:00 Uhr
          </p>
        </div>
        <div class="bg-garden-50 rounded-lg p-6">
          <h3 class="font-semibold text-garden-800 mb-2">🔑 Schlüsselübergabe</h3>
          <p class="text-gray-600">
            Schlüsselbox am Eingang<br />
            Code wird nach Buchung mitgeteilt
          </p>
        </div>
        <div class="bg-garden-50 rounded-lg p-6">
          <h3 class="font-semibold text-garden-800 mb-2">🐕 Haustiere</h3>
          <p class="text-gray-600">
            Hunde willkommen!<br />
            Bitte bei Buchung angeben
          </p>
        </div>
        <div class="bg-garden-50 rounded-lg p-6">
          <h3 class="font-semibold text-garden-800 mb-2">💳 Zahlung</h3>
          <p class="text-gray-600">
            Kreditkarte (sofort) oder<br />
            Überweisung (innerhalb 3 Tage)
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sicherheit & Kaution -->
  <section class="py-16 bg-slate-50 border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-block bg-slate-200 text-slate-800 text-sm font-medium px-4 py-1 rounded-full mb-4">
          🔒 Sicherheit &amp; Kaution
        </span>
        <h2 class="font-display text-3xl font-bold text-garden-900 mb-4">
          Transparenz ist uns wichtig
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Damit du unbeschwert genießen kannst, hier klar und ehrlich alle Infos
          zu Kameras, Privatsphäre und Kaution.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Kameras -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <h3 class="font-display text-xl font-bold text-garden-900 mb-3 flex items-center gap-2">
            <span>📷</span> KI-gestützte Kameras
          </h3>
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span>Die Überwachung läuft <strong>ausschließlich bei Leerstand</strong> zwischen Buchungen – als Einbruchschutz auf dem abgelegenen Grundstück.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span><strong>Während deiner Buchung sind die Kameras AUS</strong> – automatisch und nachweislich.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span>Zusätzlich gibt es einen <strong>physischen AUS-Schalter</strong> vor Ort, mit dem du jederzeit die Kameras komplett vom Strom nehmen kannst.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span><strong>Keine Speicherung während Belegung</strong>. Deine Privatsphäre ist garantiert.</span>
            </li>
          </ul>
        </div>

        <!-- Kaution -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <h3 class="font-display text-xl font-bold text-garden-900 mb-3 flex items-center gap-2">
            <span>💶</span> Kaution
          </h3>
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span>Bei Buchung wird eine <strong>angemessene Kaution</strong> hinterlegt (Höhe siehe Buchungsbestätigung).</span>
            </li>
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span>Beim Check-out machen wir einen <strong>kurzen gemeinsamen Inventar-Abgleich</strong> anhand einer einfachen Checkliste.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span>Ist alles in Ordnung, wird die <strong>Kaution innerhalb weniger Tage vollständig zurückerstattet</strong>.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-garden-600 mt-0.5">✓</span>
              <span>Kleine Gebrauchsspuren sind selbstverständlich normal und kein Grund für Einbehalte.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-12 bg-garden-600 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-display text-2xl font-bold mb-4">Fragen zur Buchung?</h2>
      <p class="text-garden-100 mb-6">
        Bei Fragen oder Sonderwünschen erreichst du uns jederzeit.
      </p>
      <a href="mailto:garten@infinityspace42.de"
         class="bg-white text-garden-700 hover:bg-garden-50 px-6 py-3 rounded-lg font-semibold transition inline-block">
        Kontakt aufnehmen
      </a>
    </div>
  </section>
</Layout>
