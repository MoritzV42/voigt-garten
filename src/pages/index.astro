---
import Layout from '../layouts/Layout.astro';
import ScrollVideoPlayer from '../components/ScrollVideoPlayer';
import ReviewsWidget from '../components/ReviewsWidget';

// Garten gebaut ca. 1975, seit 2004 in Familienbesitz
const gartenBau = 1975;
const familienbesitzSeit = 2004;
const aktuellesJahr = new Date().getFullYear();
const jahreFamilienbesitz = aktuellesJahr - familienbesitzSeit;
---

<Layout title="Willkommen">
  <!-- Hero Section mit Drohnenvideo Scroll-Animation -->
  <div data-tutorial="hero-section">
  <ScrollVideoPlayer
    framePath="/images/scroll/startseite/frame-"
    frameCount={240}
    scrollHeight="250vh"
    client:load
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 data-scroll-reveal="0" class="font-display text-5xl md:text-6xl font-bold text-white mb-6 drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">
        Willkommen im Refugium Heideland
      </h1>
      <p data-scroll-reveal="1" class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto mb-2 drop-shadow-lg" style="opacity:0">
        Ein Standort von <span class="font-semibold">Refugium Naturgärten</span>.
      </p>
      <p data-scroll-reveal="2" class="text-lg md:text-xl text-white/80 max-w-3xl mx-auto mb-4 italic drop-shadow-lg" style="opacity:0">
        Opa Konrads Erbe: 5.300m² Südhang, autark mit Solar und Brunnen,<br />
        verwurzelt in Tradition und mit leiser Technik ins Heute gebracht.
      </p>
      <div data-scroll-reveal="3" class="flex flex-col sm:flex-row gap-3 justify-center text-sm md:text-base mb-8" style="opacity:0">
        <span class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-full border border-white/20">
          <span>💻</span> <strong>Deep Work</strong> · Starlink · Stille · Fokus
        </span>
        <span class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-full border border-white/20">
          <span>🍇</span> <strong>Romantik</strong> · Weinberg · Südhang · Abgeschiedenheit
        </span>
        <span class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-full border border-white/20">
          <span>👨‍👩‍👧‍👦</span> <strong>Familien, Feiern & Feste</strong> · Platz · Natur · Erinnerungen
        </span>
      </div>
      <div data-scroll-reveal="3" class="flex flex-col sm:flex-row gap-4 justify-center" style="opacity:0">
        <a href="/buchen" class="bg-white hover:bg-garden-50 text-garden-800 px-8 py-4 rounded-lg font-semibold text-lg transition shadow-lg hover:shadow-xl">
          Jetzt Buchen
        </a>
        <a href="/galerie" class="bg-white/15 hover:bg-white/25 text-white px-8 py-4 rounded-lg font-semibold text-lg transition border-2 border-white/30 backdrop-blur-sm">
          Galerie ansehen
        </a>
      </div>
    </div>
  </ScrollVideoPlayer>
  </div>

  <!-- Was dich erwartet - Erweitert -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center text-garden-900 mb-12">
        Was dich erwartet
      </h2>

      <!-- Feature Cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">☀️</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Solar-Autarkie</h3>
          <p class="text-sm text-garden-600 mt-1">700W PV + 1,4kWh Akku</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">💧</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Eigener Brunnen</h3>
          <p class="text-sm text-garden-600 mt-1">50 Meter tief</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">📡</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Starlink-Internet</h3>
          <p class="text-sm text-garden-600 mt-1">Remote-Work möglich</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">🍇</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Eigener Weinberg</h3>
          <p class="text-sm text-garden-600 mt-1">Alte Reben am Südhang</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">🌳</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Alte Eichen</h3>
          <p class="text-sm text-garden-600 mt-1">Baumriesen mit Geschichte</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">🌄</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">5.300m² Südhang</h3>
          <p class="text-sm text-garden-600 mt-1">Sonne den ganzen Tag</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl font-bold text-garden-600 mb-2">{jahreFamilienbesitz}</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Jahre Familienbesitz</h3>
          <p class="text-sm text-garden-600 mt-1">Erbaut 1975 · Seit 2004 in der Familie</p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6 text-center hover:shadow-lg transition">
          <div class="text-4xl mb-2">⚙️</div>
          <h3 class="font-display text-lg font-semibold text-garden-800">Tech for Good</h3>
          <p class="text-sm text-garden-600 mt-1">Leise Technik, großer Nutzen</p>
        </div>
      </div>

      <!-- Hanglage-Hinweis -->
      <div class="bg-garden-50 border-l-4 border-garden-400 rounded-r-lg p-5 mb-10 max-w-3xl mx-auto">
        <div class="flex items-start gap-3">
          <span class="text-2xl">🌄</span>
          <div>
            <h3 class="font-display text-lg font-semibold text-garden-900 mb-1">Idyllischer Südhang – sanfte Neigung (~10–15°)</h3>
            <p class="text-sm text-garden-800 leading-relaxed">
              Der Garten liegt an einem freundlichen Südhang – perfekt für Familienausflüge,
              auch mit Kindern. Festes Schuhwerk ist hilfreich, mehr Abenteuer als Hindernis.
            </p>
          </div>
        </div>
      </div>

      <!-- Der Garten - Beschreibung -->
      <div class="bg-gradient-to-br from-garden-50 to-green-50 rounded-2xl p-8 md:p-12">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <span class="inline-block bg-garden-100 text-garden-800 text-sm font-medium px-3 py-1 rounded-full mb-4">
              5.300 m² Natur pur
            </span>
            <p class="text-gray-600 mb-6 text-lg">
              Auf einem sonnigen Südhang im Rosental gelegen, vollständig autark mit eigener
              Solaranlage und Brunnen. Alte Obstbäume, mächtige Eichen und ein kleiner Weinberg
              warten auf dich.
            </p>
            <a href="/ueber-den-garten" class="inline-flex items-center gap-2 bg-garden-600 hover:bg-garden-700 text-white px-6 py-3 rounded-lg font-medium transition">
              Mehr erfahren <span>→</span>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-4 text-center shadow-sm">
              <div class="text-2xl font-bold text-garden-600">☀️ 700W</div>
              <div class="text-xs text-gray-500 mt-1">Solaranlage</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center shadow-sm">
              <div class="text-2xl font-bold text-garden-600">💧 50m</div>
              <div class="text-xs text-gray-500 mt-1">Brunnen</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center shadow-sm">
              <div class="text-2xl font-bold text-garden-600">🔋 1,4kWh</div>
              <div class="text-xs text-gray-500 mt-1">Batterie</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center shadow-sm">
              <div class="text-2xl font-bold text-garden-600">100%</div>
              <div class="text-xs text-gray-500 mt-1">Autark</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="py-16 bg-garden-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center text-garden-900 mb-12">
        Was unsere Gäste sagen
      </h2>
      <ReviewsWidget client:load />
    </div>
  </section>

  <!-- Help Section -->
  <section class="py-16 bg-garden-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold mb-4">
        Hilf mit, den Garten zu pflegen!
      </h2>
      <p class="text-lg text-garden-100 mb-8">
        Opas Garten braucht regelmäßige Pflege. Wer freiwillig mit anpackt, bekommt als Dankeschön einen Gutschein für den nächsten Aufenthalt.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/taskmanagement" class="bg-white text-garden-700 hover:bg-garden-50 px-8 py-4 rounded-lg font-semibold text-lg transition">
          Aufgaben ansehen
        </a>
        <a href="/taskmanagement" class="bg-garden-700 hover:bg-garden-800 text-white px-8 py-4 rounded-lg font-semibold text-lg transition border-2 border-garden-500">
          Mitmach-Aktionen
        </a>
      </div>
    </div>
  </section>

</Layout>
