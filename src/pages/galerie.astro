---
import Layout from '../layouts/Layout.astro';
import GalleryUpload from '../components/GalleryUpload';
import GalleryGrid from '../components/GalleryGrid';
---

<Layout title="Galerie" description="Fotos und Videos vom Refugium Etzdorf">
  <!-- Header -->
  <section class="bg-gradient-to-b from-garden-100 to-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-garden-900 mb-4">
        Galerie
      </h1>
      <p class="text-xl text-garden-700 max-w-2xl mx-auto">
        Fotos und Videos vom Refugium Etzdorf. Teile deine Eindrücke mit uns!
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Gallery Grid (2/3) -->
        <div class="lg:col-span-2">
          <GalleryGrid client:load />
        </div>

        <!-- Upload & Info Sidebar (1/3) -->
        <div class="space-y-6">
          <!-- Upload Component -->
          <GalleryUpload client:load />

          <!-- Categories Info -->
          <div class="bg-white rounded-xl shadow-lg p-6">
            <h3 class="font-semibold text-garden-800 mb-4">📂 Kategorien</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <span>🏡</span> Gartenhaus
              </li>
              <li class="flex items-center gap-2">
                <span>🪴</span> Terrasse
              </li>
              <li class="flex items-center gap-2">
                <span>🚁</span> Luftaufnahmen
              </li>
              <li class="flex items-center gap-2">
                <span>🌻</span> Beete
              </li>
              <li class="flex items-center gap-2">
                <span>🌿</span> Wiese/Rasen
              </li>
              <li class="flex items-center gap-2">
                <span>🌳</span> Bäume/Hecken
              </li>
              <li class="flex items-center gap-2">
                <span>📷</span> Sonstiges
              </li>
            </ul>
          </div>

          <!-- Tips -->
          <div class="bg-garden-50 rounded-xl p-6">
            <h3 class="font-semibold text-garden-800 mb-3">💡 Tipps fürs Hochladen</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li>• Mehrere Dateien auf einmal möglich</li>
              <li>• Drag & Drop funktioniert!</li>
              <li>• Videos: MP4, MOV, WebM</li>
              <li>• Bilder: JPG, PNG, GIF, HEIC</li>
              <li>• Name & Beschreibung optional</li>
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Featured Seasons -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl font-bold text-garden-900 mb-8 text-center">
        Der Garten im Wandel der Jahreszeiten
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-6 text-center shadow hover:shadow-lg transition">
          <div class="text-4xl mb-2">🌸</div>
          <h3 class="font-semibold text-garden-800">Frühling</h3>
          <p class="text-sm text-gray-600">Wenn der Garten erwacht</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow hover:shadow-lg transition">
          <div class="text-4xl mb-2">☀️</div>
          <h3 class="font-semibold text-garden-800">Sommer</h3>
          <p class="text-sm text-gray-600">Volle Pracht</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow hover:shadow-lg transition">
          <div class="text-4xl mb-2">🍂</div>
          <h3 class="font-semibold text-garden-800">Herbst</h3>
          <p class="text-sm text-gray-600">Goldene Farben</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow hover:shadow-lg transition">
          <div class="text-4xl mb-2">❄️</div>
          <h3 class="font-semibold text-garden-800">Winter</h3>
          <p class="text-sm text-gray-600">Stille & Ruhe</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
