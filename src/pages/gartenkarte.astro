---
import Layout from '../layouts/Layout.astro';
import GartenkarteWrapper from '../components/GartenkarteWrapper';
---

<Layout title="Gartenkarte" description="Interaktive Karte des Refugium Heideland">
  <section class="bg-gradient-to-b from-garden-100 to-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-garden-900 mb-4">
        Gartenkarte
      </h1>
      <p class="text-xl text-garden-700 max-w-2xl mx-auto">
        Interaktive Karte mit allen Bereichen des Gartens. Klicke auf einen Bereich, um die zugehörigen Fotos zu sehen.
      </p>
    </div>
  </section>
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-tutorial="garden-map">
      <GartenkarteWrapper client:load />
    </div>
  </section>
</Layout>
