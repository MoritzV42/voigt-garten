---
import Layout from '../layouts/Layout.astro';
import SeasonCalendar from '../components/SeasonCalendar';
---

<Layout title="Saisonkalender" description="Was erwartet dich wann im Refugium Heideland? Frühling, Sommer, Herbst & Winter – jede Jahreszeit hat ihren Reiz.">

  <!-- Hero -->
  <section class="bg-gradient-to-b from-garden-800 to-garden-900 py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-garden-700/50 text-garden-200 text-sm font-medium px-4 py-1 rounded-full mb-4 border border-garden-600/30">
        Vier Jahreszeiten, ein Garten
      </span>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">
        Saisonkalender
      </h1>
      <p class="text-lg text-garden-200 max-w-2xl mx-auto">
        Der Garten verändert sich mit jeder Jahreszeit. Kirschblüte im Frühling,
        Weinlese im Herbst, Kaminfeuer im Winter – wann ist deine Zeit?
      </p>
    </div>
  </section>

  <!-- Season Calendar -->
  <section class="py-12 sm:py-16 bg-garden-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <SeasonCalendar client:load />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-garden-900 mb-4">
        Wann darf es sein?
      </h2>
      <p class="text-gray-600 mb-8">
        Jede Saison hat ihren Charme. Schau in den Buchungskalender und finde deinen Termin.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/buchen" class="bg-garden-600 hover:bg-garden-700 text-white px-8 py-4 rounded-lg font-semibold text-lg transition shadow-md hover:shadow-lg">
          Jetzt Buchen
        </a>
        <a href="/galerie" class="bg-garden-100 hover:bg-garden-200 text-garden-800 px-8 py-4 rounded-lg font-semibold text-lg transition">
          Galerie ansehen
        </a>
      </div>
    </div>
  </section>

</Layout>
