---
import Layout from '../layouts/Layout.astro';
import JobApplicationForm from '../components/JobApplicationForm';
---

<Layout
  title="Jobs & Mitmachen"
  description="Refugium Naturgärten sucht Menschen, die mit anpacken: Tech-Aushilfe, Elektro-Meister, Gärtner, oder Initiativbewerbung. 5.300 m² Südhang in Heideland, autarkes Refugium im Aufbau."
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-b from-garden-100 via-garden-50 to-white py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 left-10 text-9xl">🌿</div>
      <div class="absolute bottom-10 right-10 text-9xl">🌳</div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-garden-200/60 text-garden-800 text-xs font-medium uppercase tracking-widest px-3 py-1 rounded-full mb-6">
        Refugium Naturgärten · Standort Heideland
      </span>
      <h1 class="font-display text-4xl md:text-6xl font-bold text-garden-900 mb-6 leading-tight">
        Werde Teil von<br />Refugium Naturgärten
      </h1>
      <p class="text-lg md:text-xl text-garden-800/90 max-w-2xl mx-auto leading-relaxed">
        Wir bauen ein autarkes Refugium auf 5.300 m² Südhang in Heideland — und
        suchen Menschen, die mit anpacken.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="#offene-rollen"
          class="inline-block bg-garden-700 hover:bg-garden-800 text-white px-6 py-3 rounded-lg font-medium transition shadow-sm"
        >
          Offene Rollen ansehen
        </a>
        <a
          href="#bewerben"
          class="inline-block bg-white hover:bg-garden-50 text-garden-800 border border-garden-200 px-6 py-3 rounded-lg font-medium transition"
        >
          Direkt bewerben
        </a>
      </div>
    </div>
  </section>

  <!-- Content-Sektionen (Task #20) -->
  <section id="worum-es-geht" class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-garden-900 mb-4">
        Worum es hier geht
      </h2>
      <div class="space-y-5 text-gray-700 text-lg leading-relaxed">
        <p>
          Refugium Heideland ist mehr als ein Garten. 5.300 m² Südhang in Heideland,
          eigener Brunnen, Solar-Autarkie, Gartenhaus, Wintergarten, alter
          Baumbestand — und ein Ort, der langsam wächst, statt schnell fertig
          zu werden.
        </p>
        <p>
          Wir bauen hier ein naturnahes Refugium mit Übernachtungsmöglichkeit
          auf. Die Basis steht, aber vieles ist in Bewegung: Infrastruktur, die
          repariert werden will. Pflanzen, die gepflegt werden wollen. Technik,
          die sauber eingerichtet werden muss. Ein Kooperationsmodell, das
          lebt.
        </p>
        <p class="text-garden-800 italic">
          Dieses Projekt trägt Opa Konrads Erbe weiter — ein Stück Familie,
          naturverbunden, mit offenen Türen für die, die es verstehen.
        </p>
      </div>
    </div>
  </section>

  <!-- Offene Rollen -->
  <section id="offene-rollen" class="py-16 md:py-20 bg-garden-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-garden-900 mb-3">
          Offene Rollen
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Vier Wege, wie du Teil von Refugium Naturgärten werden kannst.
          Minijob, Honorarbasis oder projektweise — wir finden einen Rahmen,
          der passt.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Card 1: Tech-Aushilfe / Student -->
        <div class="bg-white rounded-2xl shadow-sm border border-garden-100 p-8 hover:shadow-md transition">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-4xl">💻</div>
            <div>
              <h3 class="font-display text-xl font-semibold text-garden-900">
                Tech-Aushilfe / Student
              </h3>
              <p class="text-sm text-garden-600 mt-1">
                Minijob · flexibel · remote-freundlich
              </p>
            </div>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Du kennst dich mit modernen Web-Stacks aus (Astro, React, Python,
            Docker) und hast Lust, an einem lebendigen Projekt mitzubauen —
            Buchungssystem, Galerie, Admin-Tools, Sensorik.
          </p>
          <ul class="text-sm text-gray-600 space-y-1.5 mb-6">
            <li class="flex gap-2"><span class="text-garden-600">·</span> Kleine Features umsetzen, Bugs fixen</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Deployment-Pipelines pflegen</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Gerne auch Experimente (LLM, Automatisierung)</li>
          </ul>
          <a
            href="#bewerben"
            data-position="tech_student"
            class="job-apply-link inline-flex items-center gap-1 text-garden-700 hover:text-garden-900 font-medium text-sm"
          >
            Für diese Rolle bewerben →
          </a>
        </div>

        <!-- Card 2: Elektro-Meister / E-Check -->
        <div class="bg-white rounded-2xl shadow-sm border border-garden-100 p-8 hover:shadow-md transition">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-4xl">⚡</div>
            <div>
              <h3 class="font-display text-xl font-semibold text-garden-900">
                Elektro-Meister / E-Check
              </h3>
              <p class="text-sm text-garden-600 mt-1">
                Honorarbasis · projektweise
              </p>
            </div>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Die Elektrik im Gartenhaus braucht eine saubere Abnahme (E-Check),
            punktuell auch kleinere Arbeiten an der Solaranlage und der
            Unterverteilung.
          </p>
          <ul class="text-sm text-gray-600 space-y-1.5 mb-6">
            <li class="flex gap-2"><span class="text-garden-600">·</span> E-Check mit Prüfprotokoll</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Solaranlage 700 W + 1,4 kWh Akku</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Region Heideland / Thüringen bevorzugt</li>
          </ul>
          <a
            href="#bewerben"
            data-position="elektro_meister"
            class="job-apply-link inline-flex items-center gap-1 text-garden-700 hover:text-garden-900 font-medium text-sm"
          >
            Für diese Rolle bewerben →
          </a>
        </div>

        <!-- Card 3: Gärtner / Instandhaltung -->
        <div class="bg-white rounded-2xl shadow-sm border border-garden-100 p-8 hover:shadow-md transition">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-4xl">🌳</div>
            <div>
              <h3 class="font-display text-xl font-semibold text-garden-900">
                Gärtner / Instandhaltung
              </h3>
              <p class="text-sm text-garden-600 mt-1">
                Minijob oder Honorar · vor Ort
              </p>
            </div>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Regelmäßige Pflege des Grundstücks: Rasen, Beete, Obstbäume, kleine
            Reparaturen am Gartenhaus und den Nebengebäuden. Wer den Ort
            kennenlernt, kennt ihn bald besser als wir.
          </p>
          <ul class="text-sm text-gray-600 space-y-1.5 mb-6">
            <li class="flex gap-2"><span class="text-garden-600">·</span> Baumpflege (Kirsche, Eiche, Esche)</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Instandhaltung Schuppen & Carport</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Selbstständig arbeiten, mitdenken</li>
          </ul>
          <a
            href="#bewerben"
            data-position="gaertner"
            class="job-apply-link inline-flex items-center gap-1 text-garden-700 hover:text-garden-900 font-medium text-sm"
          >
            Für diese Rolle bewerben →
          </a>
        </div>

        <!-- Card 4: Initiativbewerbung -->
        <div class="bg-white rounded-2xl shadow-sm border-2 border-dashed border-garden-200 p-8 hover:shadow-md transition">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-4xl">✨</div>
            <div>
              <h3 class="font-display text-xl font-semibold text-garden-900">
                Initiativbewerbung
              </h3>
              <p class="text-sm text-garden-600 mt-1">
                Was anderes im Kopf? Erzähl's uns.
              </p>
            </div>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Kochen für Gäste, Workshops anbieten, Fotografie, Social Media,
            handwerkliche Projekte — wenn du eine Idee hast, wie du zum
            Refugium beitragen kannst, schreib uns.
          </p>
          <ul class="text-sm text-gray-600 space-y-1.5 mb-6">
            <li class="flex gap-2"><span class="text-garden-600">·</span> Offene Kategorie, alle Skills willkommen</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Beschreib deine Idee in der Motivation</li>
            <li class="flex gap-2"><span class="text-garden-600">·</span> Wir melden uns ehrlich zurück</li>
          </ul>
          <a
            href="#bewerben"
            data-position="initiativ"
            class="job-apply-link inline-flex items-center gap-1 text-garden-700 hover:text-garden-900 font-medium text-sm"
          >
            Initiativ bewerben →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Was dich erwartet -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-garden-900 mb-8 text-center">
        Was dich erwartet
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-garden-50 rounded-xl p-6">
          <div class="text-3xl mb-3">🌱</div>
          <h3 class="font-semibold text-garden-900 mb-2">Ein Ort mit Geschichte</h3>
          <p class="text-gray-700 text-sm leading-relaxed">
            5.300 m² Südhang mit altem Baumbestand, Gartenhaus, Wintergarten
            und eigenem Brunnen. Keine Kulisse, sondern ein echter Familienort,
            der weiterlebt.
          </p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6">
          <div class="text-3xl mb-3">🤝</div>
          <h3 class="font-semibold text-garden-900 mb-2">Faire Bedingungen</h3>
          <p class="text-gray-700 text-sm leading-relaxed">
            Wir zahlen fair und pünktlich. Minijob, Honorar oder projektweise —
            je nachdem, was für dich und uns passt. Kein Bullshit.
          </p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6">
          <div class="text-3xl mb-3">🔧</div>
          <h3 class="font-semibold text-garden-900 mb-2">Echte Verantwortung</h3>
          <p class="text-gray-700 text-sm leading-relaxed">
            Du übernimmst deinen Bereich. Wir brauchen keine ausführenden
            Hände, sondern Menschen, die mitdenken und Dinge verbessern.
          </p>
        </div>
        <div class="bg-garden-50 rounded-xl p-6">
          <div class="text-3xl mb-3">⚙️</div>
          <h3 class="font-semibold text-garden-900 mb-2">Moderne Tools</h3>
          <p class="text-gray-700 text-sm leading-relaxed">
            Task-Management, Inventar, Karte, Galerie — alles digital
            organisiert. Du musst nichts auf Zuruf im Kopf behalten.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bewerbungsform -->
  <section id="bewerben" class="py-16 md:py-20 bg-gradient-to-b from-garden-50 to-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-garden-900 mb-3">
          Jetzt bewerben
        </h2>
        <p class="text-gray-600">
          Schreib uns ein paar ehrliche Zeilen. Wir antworten persönlich.
        </p>
      </div>
      <JobApplicationForm client:load />
    </div>
  </section>

  <!-- Kontakt-Fußnote -->
  <section class="pb-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-sm text-gray-500">
        Fragen vorab? Schreib direkt an{' '}
        <a href="mailto:garten@infinityspace42.de" class="text-garden-700 hover:text-garden-900 underline">
          garten@infinityspace42.de
        </a>
      </p>
    </div>
  </section>

  <!-- Client-Script: Card-Link setzt Position in der Form vor -->
  <script>
    document.querySelectorAll('.job-apply-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const pos = (e.currentTarget as HTMLElement).getAttribute('data-position');
        if (pos) {
          try {
            sessionStorage.setItem('preselectPosition', pos);
          } catch {}
          // Form reagiert per 'storage' oder beim Mount — zusätzlich CustomEvent
          window.dispatchEvent(new CustomEvent('preselect-position', { detail: pos }));
        }
      });
    });
  </script>
</Layout>
